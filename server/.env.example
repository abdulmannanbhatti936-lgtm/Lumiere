NODE_ENV=development
PORT=3000

# Local dev: matches docker-compose.yml (port 5433, to avoid clashing with a native Postgres install on 5432).
# Swap for your Supabase connection string at deploy time.
DATABASE_URL=postgresql://lumiere:lumiere_dev_password@localhost:5433/lumiere_stays

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret

CLIENT_URL=http://localhost:5173

# General API abuse protection, requests/min per IP (spec default: 10). Raise this
# if legitimate SPA usage starts tripping it.
RATE_LIMIT_MAX=10

STRIPE_SECRET_KEY=sk_test_replace_me
# From `stripe listen --forward-to localhost:3000/api/webhooks/stripe` locally, or the Stripe Dashboard webhook config in production.
STRIPE_WEBHOOK_SECRET=whsec_replace_me
RESEND_API_KEY=re_replace_me
EMAIL_FROM=Lumiere Stays <bookings@yourdomain.com>

# Powers the Lumière Concierge chat assistant (client/src/components/chat/ChatWidget.tsx).
# Get a key from https://console.mistral.ai — the widget shows a friendly "not configured"
# message and the rest of the site works fine if this is left blank.
MISTRAL_API_KEY=
